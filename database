CREATE TEMP TABLE guest_checkouts as 
SELECT * FROM retail_sales 
WHERE CustomerID IS NULL;

CREATE TEMP TABLE return_count as 
SELECT COUNT(*) FROM retail_sales
WHERE InvoiceNo LIKE 'C%' AND Quantity < 0
GROUP BY InvoiceNo, Quantity;

CREATE TEMP TABLE actual_purchase as 
SELECT COUNT(*) FROM retail_sales
WHERE Quantity > 0;

CREATE TEMP TABLE revenue as 
SELECT InvoiceNo, StockCode, Description, Quantity, InvoiceDate, UnitPrice, CustomerId, Country, Quantity*UnitPrice AS totalrevenue
FROM retail_sales;

CREATE TEMP TABLE highestsales as 
SELECT Country, RANK() OVER(ORDER BY totalrevenue DESC)
FROM revenue LIMIT 5;

CREATE TEMP TABLE PopularProduct as 
SELECT StockCode, Description, RANK() OVER(ORDER BY Quantity DESC)
FROM retail_sales
LIMIT 5;

WITH recency AS 
(
    SELECT
        CustomerID,
        CAST(
            julianday(DATE((SELECT MAX(InvoiceDate) FROM retail_sales))) -
            julianday(DATE(MAX(InvoiceDate)))
            AS INTEGER
        ) AS recency_days
    FROM retail_sales
    WHERE CustomerID IS NOT NULL
    GROUP BY CustomerID
),
frequency AS 
(
    SELECT CustomerID, COUNT(*) AS frequency_count 
    FROM retail_sales
    WHERE CustomerID IS NOT NULL AND Quantity > 0
    GROUP BY CustomerID
),
monetary AS 
(
    SELECT CustomerID, SUM(Quantity*unitprice) AS total_spend
    FROM retail_sales
    WHERE CustomerID IS NOT NULL
    GROUP BY CustomerID
),
rmf_raw AS (
    SELECT r.CustomerID, r.recency_days, f.frequency_count, m.total_spend
    FROM recency r 
    JOIN frequency f ON r.CustomerID = f.CustomerID
    JOIN monetary m ON r.CustomerID = m.CustomerID
),
scores AS (
    SELECT *,
    NTILE(5) OVER(ORDER BY recency_days DESC) AS R_score,
    NTILE(5) OVER(ORDER BY frequency_count ASC) AS F_score,
    NTILE(5) OVER(ORDER BY total_spend ASC) AS M_score
    FROM rmf_raw
),
levels AS 
(
    SELECT *,
    CASE 
        WHEN R_score IN (4,5) AND F_score IN (4,5) THEN "champions"
        WHEN R_score IN (1,2) AND F_score IN (1,2) THEN "loss"
        WHEN R_score = 1 AND F_score IN (1,2) THEN "about to sleep"
        ELSE "average customers"
    END FROM scores
)
SELECT * FROM levels; 
DROP TABLE IF EXISTS customer_cohorts;

CREATE TEMP TABLE customer_cohorts AS
WITH customer_first_purchase AS (
    SELECT 
        CustomerId,
        MIN(InvoiceDate) AS first_purchase_date,
        strftime('%Y-%m', MIN(InvoiceDate)) AS cohort_month
    FROM retail_sales
    WHERE CustomerId IS NOT NULL
    GROUP BY CustomerId
),
ans AS (
    SELECT 
        r.CustomerId,
        c.cohort_month,
        ((strftime('%Y', r.InvoiceDate) - strftime('%Y', c.first_purchase_date)) * 12) +
        (strftime('%m', r.InvoiceDate) - strftime('%m', c.first_purchase_date)) AS period_month
    FROM retail_sales r
    JOIN customer_first_purchase c ON r.CustomerId = c.CustomerId
)
SELECT * FROM ans;
SELECT 
    cohort_month AS "Cohort",
    COUNT(DISTINCT CASE WHEN period_month = 0 THEN CustomerId END) AS "Size (Month 0)",
    COUNT(DISTINCT CASE WHEN period_month = 1 THEN CustomerId END) AS "Month 1",
    COUNT(DISTINCT CASE WHEN period_month = 2 THEN CustomerId END) AS "Month 2",
    COUNT(DISTINCT CASE WHEN period_month = 3 THEN CustomerId END) AS "Month 3"
FROM customer_cohorts
WHERE cohort_month = '2026-01'
GROUP BY cohort_month;
